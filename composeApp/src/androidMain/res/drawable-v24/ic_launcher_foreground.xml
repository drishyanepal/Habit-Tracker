<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft drop shadow -->
    <path
        android:fillColor="#221565C0"
        android:pathData="M23,58 A33,33 0 1 0 89,58 A33,33 0 1 0 23,58 Z" />

    <!-- Main circle — blue radial gradient -->
    <path android:pathData="M21,54 A33,33 0 1 0 87,54 A33,33 0 1 0 21,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="45"
                android:centerY="45"
                android:gradientRadius="48">
                <item android:offset="0.0" android:color="#FF82CFFF" />
                <item android:offset="0.45" android:color="#FF2196F3" />
                <item android:offset="1.0" android:color="#FF0D47A1" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- White ring -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M30,54 A24,24 0 1 0 78,54 A24,24 0 1 0 30,54 Z" />

    <!-- Red ring -->
    <path
        android:fillColor="#FFE53935"
        android:pathData="M38,54 A16,16 0 1 0 70,54 A16,16 0 1 0 38,54 Z" />

    <!-- White center -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M46,54 A8,8 0 1 0 62,54 A8,8 0 1 0 46,54 Z" />

    <!-- Crosshair lines -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#33000000"
        android:strokeWidth="1.2"
        android:pathData="M30,54 L78,54" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#33000000"
        android:strokeWidth="1.2"
        android:pathData="M54,30 L54,78" />

    <!-- Dart shaft -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFD740"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M75,33 L60,48" />

    <!-- Dart arrowhead -->
    <path
        android:fillColor="#FFFFD740"
        android:pathData="M54,54 L63,51 L60,48 L57,45 Z" />

    <!-- Dart tail flights (X shape) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFD740"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M72,30 L78,36 M72,36 L78,30" />

    <!-- Gleam arc -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#44FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M33,42 A24,24 0 0 1 54,22" />

</vector>
